NODE_ENV=development
PORT=3000
# Chỉ dùng khi deploy qua Nginx (xem docs/deploy-vps.md) - bind 127.0.0.1 để
# Node không lộ trực tiếp ra internet. Bỏ trống/không set khi dev local.
HOST=127.0.0.1

# Dev local: dùng trực tiếp DATABASE_URL/REDIS_URL như dưới đây.
# Production (backend/docker-compose.yml): set MYSQL_ROOT_PASSWORD và
# REDIS_PASSWORD, rồi dùng CÙNG giá trị đó trong DATABASE_URL/REDIS_URL.
MYSQL_ROOT_PASSWORD=root
DATABASE_URL="mysql://root:root@localhost:3306/social_analyzer"
REDIS_PASSWORD=
REDIS_URL="redis://localhost:6379"
AI_PROVIDER="mock"
# Đổi AI_PROVIDER="openai" để dùng OpenAI thật, cần AI_API_KEY là khóa API
# từ https://platform.openai.com (dạng sk-...).
AI_API_KEY="your_ai_api_key"
AI_MODEL="gpt-5.4-nano"
CORS_ORIGIN="chrome-extension://your-extension-id,http://localhost:5173"
